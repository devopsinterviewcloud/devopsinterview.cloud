# DevOpsInterview.Cloud - Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@localhost:5432/database_name
DATABASE_URL="postgresql://username:password@localhost:5432/devopsinterview"

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================

# RAZORPAY — domestic payments (India, INR)
# Get from: https://dashboard.razorpay.com/app/keys
# Use test keys for development (rzp_test_), live keys for production (rzp_live_)
RAZORPAY_KEY_ID="rzp_test_your_key_id_here"
RAZORPAY_KEY_SECRET="your_razorpay_secret_here"
# Webhook secret from Razorpay Dashboard > Webhooks (verify HMAC SHA256 on the raw body)
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret_here"

# PAYPAL — international payments (USD and other currencies)
# Get from: https://developer.paypal.com/dashboard/applications
# Use sandbox credentials for development, live for production
PAYPAL_CLIENT_ID="your_paypal_client_id_here"
PAYPAL_CLIENT_SECRET="your_paypal_client_secret_here"
# 'sandbox' or 'live'
PAYPAL_ENV="sandbox"
# Webhook ID from PayPal Dashboard > Webhooks (used to verify webhook signatures)
PAYPAL_WEBHOOK_ID="your_paypal_webhook_id_here"

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get from: https://supabase.com/dashboard > Settings > API
# Project URL is on the API settings page (NOT the API Keys page).
SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase rolled out a NEW key format. The env var NAMES below are unchanged;
# only the values differ. New project -> use the new keys:
#   SUPABASE_ANON_KEY          <- "Publishable key"  (sb_publishable_...)  safe for browser
#   SUPABASE_SERVICE_ROLE_KEY  <- "Secret key"       (sb_secret_...)       server-only
# Legacy projects still show JWT-style anon / service_role keys; either format
# works in the same slot. Only the secret/service_role key is actually required
# here (storage.ts signs private-bucket download URLs server-side).
SUPABASE_ANON_KEY="sb_publishable_your_publishable_key_here"

# Secret key / service_role (for server-side operations: signed download URLs).
# Bypasses Row-Level Security. Keep this secret; never expose to client-side code.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_your_secret_key_here"

# PRIVATE bucket holding the book PDFs (signed URLs are generated for delivery).
# Create it in Supabase Storage and upload the PDFs; map slugs in src/lib/storage.ts.
SUPABASE_EBOOKS_BUCKET="ebooks"

# Secret used to sign short-lived download links (openssl rand -base64 32)
DOWNLOAD_TOKEN_SECRET="generate-a-long-random-string"

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key_here"

# Email sender configuration.
# IMPORTANT: Resend cannot send "from" a @gmail.com address. The FROM must be an
# address on a domain you have verified in Resend (you own devopsinterview.cloud,
# so verify it there). Put your real inbox (the gmail) as the reply-to so replies
# reach you.
EMAIL_FROM="DevOpsInterview.Cloud <noreply@devopsinterview.cloud>"
EMAIL_REPLY_TO="devopsinterview.cloud@gmail.com"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Your application URL (without trailing slash)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# AUTHENTICATION (Future use)
# =============================================================================
# Generate a secure random string (32+ characters)
# You can use: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-nextauth-key-here"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# =============================================================================
# DEVELOPMENT/DEBUGGING
# =============================================================================
# Set to 'true' to enable bundle analyzer
ANALYZE="false"

# Set to 'development' or 'production'
NODE_ENV="development"

# =============================================================================
# REDIS CONFIGURATION (Required for Production)
# =============================================================================
# Upstash Redis for rate limiting (required for multi-instance deployments)
# Get from: https://console.upstash.com
# Free tier available: 10,000 commands/day
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token_here"

# =============================================================================
# SECURITY (Production Only)
# =============================================================================
# Add additional security keys as needed
# Example: API rate limiting secrets, encryption keys, etc.

# =============================================================================
# IMPORTANT SECURITY NOTES
# =============================================================================
# 1. Never commit this file with real values to version control
# 2. Use different values for development, staging, and production
# 3. Rotate secrets regularly in production
# 4. Use your deployment platform's secret management (Vercel, Railway, etc.)
# 5. Validate all environment variables on application startup